{
  "name": "docflow",
  "version": "0.1.0",
  "description": "CLI tool that helps SMEs produce engaging, research-backed documentation",
  "type": "module",
  "bin": {
    "docflow": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/templates dist/templates",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'"
  },
  "keywords": [
    "documentation",
    "cli",
    "engagement",
    "validation"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.2",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  }
}
